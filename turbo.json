{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**"]
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:studio": {
			"cache": false
		},
		"check-types": {
			"cache": false
		},
		"check": {
			"cache": false
		},
		"package": {
			"dependsOn": ["build"],
			"outputs": ["dist/**"],
			"cache": false
		},
		"desktop:pack": {
			"dependsOn": ["desktop:build"],
			"outputs": ["dist/**"]
		},
		"desktop:build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		}
	}
}
