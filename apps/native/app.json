{
	"expo": {
		"version": "1.2.2",
		"scheme": "finance-tracker",
		"userInterfaceStyle": "automatic",
		"orientation": "default",
		"web": {
			"bundler": "metro",
			"favicon": "./assets/images/web/favicon.ico"
		},
		"name": "Finance Tracker",
		"slug": "finance-tracker",
		"plugins": [
			"expo-font",
			"expo-router",
			"expo-secure-store",
			"expo-web-browser",
			[
				"react-native-android-widget",
				{
					"widgets": [
						{
							"name": "BudgetWidget",
							"label": "Budget Tracker",
							"description": "Shows your current budgets and spending",
							"minWidth": "180dp",
							"minHeight": "110dp",
							"targetWidth": "270dp",
							"targetHeight": "270dp",
							"updatePeriodMillis": 1800000,
							"resizeMode": "vertical|horizontal",
							"previewImage": "./assets/images/icon.png"
						}
					]
				}
			],
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#ffffff",
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"dark": {
						"backgroundColor": "#09090b",
						"image": "./assets/images/splash-icon-dark.png"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"icon": "./assets/images/icon.png",
		"android": {
			"versionCode": 6,
			"package": "com.rizrmdhn.finance_tracker",
			"permissions": [
				"android.permission.REQUEST_INSTALL_PACKAGES"
			],
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			}
		},
		"ios": {
			"icon": "./assets/images/icon.png"
		}
	}
}
