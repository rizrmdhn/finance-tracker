{
	"name": "@finance-tracker/native",
	"version": "1.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"postinstall": "patch-package",
		"start": "expo start",
		"dev": "expo start --clear",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"prebuild": "expo prebuild",
		"web": "expo start --web",
		"doctor": "bunx expo-doctor",
