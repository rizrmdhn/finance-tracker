{
	"name": "@finance-tracker/desktop",
	"version": "1.4.0",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "(cd ../web && bun run build) && electron-vite build && rm -rf out/renderer && cp -r ../web/dist out/renderer",
		"rebuild": "electron-rebuild -f -w better-sqlite3",
		"package": "bun run build && electron-builder --win",
		"package:dir": "bun run build && electron-builder --win --dir",
		"check-types": "tsc --noEmit",
		"postinstall": "electron-builder install-app-deps"
	},
	"build": {
		"appId": "com.finance-tracker.desktop",
		"productName": "Finance Tracker",
		"publish": {
			"provider": "github",
			"owner": "rizrmdhn",
			"repo": "finance-tracker"
		},
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*"
		],
		"extraResources": [
			{
				"from": "../../packages/db/migrations",
				"to": "migrations"
			}
		],
		"asarUnpack": [
			"**/better-sqlite3/**",
			"**/node_modules/better-sqlite3/**"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "src/resources/icon.ico"
		},
		"nsis": {
			"oneClick": true,
			"perMachine": false,
			"allowToChangeInstallationDirectory": false,
			"artifactName": "Finance-Tracker-Setup-${version}.${ext}"
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"icon": "src/resources/icon.icns",
			"artifactName": "Finance-Tracker-${version}-${arch}.${ext}"
		},
		"linux": {
			"target": [
				{
					"target": "AppImage",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "src/resources/icon.png",
			"artifactName": "Finance-Tracker-${version}.${ext}"
		},
		"npmRebuild": true,
		"nativeRebuilder": "sequential",
		"extraMetadata": {
			"main": "out/main/index.js"
		}
	},
	"dependencies": {
		"@finance-tracker/api": "workspace:*",
		"@finance-tracker/db": "workspace:*",
		"@finance-tracker/queries": "workspace:*",
		"@finance-tracker/schema": "workspace:*",
		"@finance-tracker/sync": "workspace:*",
		"@vlcn.io/crsqlite": "^0.16.3",
		"better-sqlite3": "catalog:",
		"bonjour-service": "^1.3.0",
		"drizzle-orm": "catalog:",
		"electron-updater": "^6.8.3",
		"trpc-electron": "^0.1.2",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@finance-tracker/constants": "workspace:*",
		"@electron/rebuild": "^3.7.2",
		"@types/better-sqlite3": "catalog:",
		"@types/ws": "^8.5.14",
		"electron": "39.2.6",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"typescript": "catalog:",
		"vite": "^7.2.6"
	}
}
