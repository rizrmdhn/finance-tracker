{
	"name": "@finance-tracker/desktop",
	"version": "0.0.1",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"rebuild": "electron-rebuild -f -w better-sqlite3",
		"package": "bun run build && electron-builder --win",
		"package:dir": "bun run build && electron-builder --win --dir"
	},
	"build": {
		"appId": "com.finance-tracker.desktop",
		"productName": "Finance Tracker",
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*"
		],
		"extraResources": [
			{
				"from": "../../packages/db/migrations",
				"to": "migrations"
			}
		],
		"asarUnpack": [
			"**/better-sqlite3/**",
			"**/node_modules/better-sqlite3/**"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "resources/icon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"npmRebuild": true,
		"nativeRebuilder": "sequential",
		"extraMetadata": {
			"main": "out/main/index.js"
		}
	},
	"dependencies": {
		"@finance-tracker/api": "workspace:*",
		"@finance-tracker/db": "workspace:*",
		"@finance-tracker/ui": "workspace:*",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.141.1",
		"@trpc/client": "catalog:",
		"better-sqlite3": "catalog:",
		"drizzle-orm": "catalog:",
		"date-fns": "catalog:",
		"electron-trpc": "^0.7.1",
		"lucide-react": "^0.577.0",
		"next-themes": "^0.4.6",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sonner": "^2.0.7"
	},
	"devDependencies": {
		"@electron/rebuild": "^3.7.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router-devtools": "^1.141.1",
		"@tanstack/router-plugin": "^1.141.1",
		"@types/better-sqlite3": "catalog:",
		"@types/react": "^19.0.0",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "^5.1.1",
		"electron": "^39.2.6",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"tailwindcss": "catalog:",
		"vite": "^7.2.6"
	}
}
