{
	"name": "@finance-tracker/desktop",
	"version": "0.0.1",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"rebuild": "electron-rebuild -f -w better-sqlite3",
		"package": "bun run build && electron-builder --win",
		"package:dir": "bun run build && electron-builder --win --dir",
		"check-types": "tsc --noEmit"
	},
	"build": {
		"appId": "com.finance-tracker.desktop",
		"productName": "Finance Tracker",
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*"
		],
		"extraResources": [
			{
				"from": "../../packages/db/migrations",
				"to": "migrations"
			}
		],
		"asarUnpack": [
			"**/better-sqlite3/**",
			"**/node_modules/better-sqlite3/**"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "resources/icon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"npmRebuild": true,
		"nativeRebuilder": "sequential",
		"extraMetadata": {
			"main": "out/main/index.js"
		}
	},
	"dependencies": {
		"@finance-tracker/api": "workspace:*",
		"@finance-tracker/db": "workspace:*",
		"@finance-tracker/ui": "workspace:*",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-router": "catalog:",
		"@trpc/client": "catalog:",
		"@trpc/tanstack-react-query": "catalog:",
		"better-sqlite3": "catalog:",
		"date-fns": "catalog:",
		"drizzle-orm": "catalog:",
		"lucide-react": "catalog:",
		"next-themes": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"recharts": "catalog:",
		"sonner": "catalog:",
		"superjson": "catalog:",
		"trpc-electron": "^0.1.2"
	},
	"devDependencies": {
		"@electron/rebuild": "^3.7.2",
		"@tailwindcss/vite": "catalog:",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router-devtools": "catalog:",
		"@tanstack/router-plugin": "catalog:",
		"@types/better-sqlite3": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "^5.1.1",
		"electron": "^39.2.6",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "^7.2.6"
	}
}
