{
	"name": "@finance-tracker/desktop",
	"version": "1.0.0",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"rebuild": "electron-rebuild -f -w better-sqlite3",
		"package": "bun run build && electron-builder --win",
		"package:dir": "bun run build && electron-builder --win --dir",
		"check-types": "tsc --noEmit"
	},
	"build": {
		"appId": "com.finance-tracker.desktop",
		"productName": "Finance Tracker",
		"publish": {
			"provider": "github",
			"owner": "rizrmdhn",
			"repo": "finance-tracker"
		},
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*"
		],
		"extraResources": [
			{
				"from": "../../packages/db/migrations",
				"to": "migrations"
			}
		],
		"asarUnpack": [
			"**/better-sqlite3/**",
			"**/node_modules/better-sqlite3/**"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "src/resources/icon.ico"
		},
		"nsis": {
			"oneClick": true,
			"perMachine": false,
			"allowToChangeInstallationDirectory": false,
			"artifactName": "Finance-Tracker-Setup-${version}.${ext}"
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"icon": "src/resources/icon.icns",
			"artifactName": "Finance-Tracker-${version}-${arch}.${ext}"
		},
		"linux": {
			"target": [
				{
					"target": "AppImage",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "src/resources/icon.png",
			"artifactName": "Finance-Tracker-${version}.${ext}"
		},
		"npmRebuild": true,
		"nativeRebuilder": "sequential",
		"extraMetadata": {
			"main": "out/main/index.js"
		}
	},
	"dependencies": {
		"@finance-tracker/api": "workspace:*",
		"@finance-tracker/db": "workspace:*",
		"@finance-tracker/schema": "workspace:*",
		"better-sqlite3": "catalog:",
		"drizzle-orm": "catalog:",
		"electron-updater": "^6.8.3",
		"trpc-electron": "^0.1.2",
		"@finance-tracker/queries": "workspace:*"
	},
	"devDependencies": {
		"@finance-tracker/constants": "workspace:*",
		"@finance-tracker/dictionaries": "workspace:*",
		"i18next": "^25.3.2",
		"react-i18next": "^15.5.3",
		"@finance-tracker/types": "workspace:*",
		"@finance-tracker/ui": "workspace:*",
		"@finance-tracker/utils": "workspace:*",
		"@electron/rebuild": "^3.7.2",
		"@hookform/resolvers": "^5.2.2",
		"@tailwindcss/vite": "catalog:",
		"@tanstack/react-query": "catalog:",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "catalog:",
		"@tanstack/react-router-devtools": "catalog:",
		"@tanstack/react-table": "catalog:",
		"@tanstack/router-plugin": "catalog:",
		"@trpc/client": "catalog:",
		"@trpc/tanstack-react-query": "catalog:",
		"@types/better-sqlite3": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@paralleldrive/cuid2": "catalog:",
		"@vitejs/plugin-react": "^5.1.1",
		"date-fns": "catalog:",
		"electron": "^39.2.6",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"lucide-react": "catalog:",
		"nanoid": "^5.1.7",
		"next-themes": "catalog:",
		"react": "catalog:",
		"react-day-picker": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "^7.71.2",
		"recharts": "catalog:",
		"sonner": "catalog:",
		"superjson": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "^7.2.6"
	}
}
