{
	"name": "finance-tracker",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@trpc/client": "^11.13.4",
			"drizzle-orm": "^0.45.1",
			"date-fns": "^4.1.0",
			"better-sqlite3": "^12.8.0",
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"sonner": "^2.0.5",
			"@types/react-dom": "^19.2.3",
			"@types/better-sqlite3": "^7.6.13",
			"tailwindcss": "^4.1.18",
			"expo-sqlite": "~55.0.11",
		"@tanstack/react-query": "^5.80.7"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F @finance-tracker/native dev",
		"dev:web": "turbo -F @finance-tracker/web dev",
		"dev:desktop": "turbo -F @finance-tracker/desktop dev",
		"desktop:build": "turbo -F @finance-tracker/desktop build",
		"desktop:pack": "turbo -F @finance-tracker/desktop package",
		"db:studio": "turbo -F @finance-tracker/db db:studio",
		"db:migrate": "turbo -F @finance-tracker/db db:migrate",
		"db:generate": "turbo -F @finance-tracker/db db:generate",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@finance-tracker/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@finance-tracker/config": "workspace:*",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.9"
}
